{
  "name": "capstonemymsu-infoguide",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --port 8081",
    "android": "expo start --android --port 8081",
    "ios": "expo start --ios --port 8081",
    "web": "expo start --web --port 8081",
    "build": "expo export -p web --output-dir dist",
    "serve": "node server.cjs",
    "render-start": "npm run build && npm run serve",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "^56.0.3",
    "expo-constants": "^56.0.14",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "^56.0.11",
    "expo-location": "~56.0.12",
    "expo-notifications": "^56.0.12",
    "expo-router": "^56.2.5",
    "expo-splash-screen": "^56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-video": "~56.1.2",
    "leaflet": "^1.9.4",
    "nodemailer": "^8.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-native-screens": "4.25.1"
  },
  "private": true
}
