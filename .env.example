# xAI/Grok keys usually start with xai-.
EXPO_PUBLIC_GROK_API_KEY=
EXPO_PUBLIC_XAI_MODEL=grok-4.3

# GroqCloud keys usually start with gsk_.
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile

# Backend API. Use your computer LAN IP on physical phones, for example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8787
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# Optional Hygraph-backed account authentication.
# Keep the PAT server-side; do not prefix it with EXPO_PUBLIC.
HYGRAPH_AUTH_ENDPOINT=
HYGRAPH_AUTH_TOKEN=
HYGRAPH_AUTH_COLLECTION=authUsers
HYGRAPH_AUTH_CREATE_MUTATION=createAuthUser
HYGRAPH_AUTH_CREATE_INPUT=AuthUserCreateInput
