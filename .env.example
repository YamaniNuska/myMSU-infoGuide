# xAI/Grok keys usually start with xai-.
EXPO_PUBLIC_GROK_API_KEY=
EXPO_PUBLIC_XAI_MODEL=grok-4.3

# GroqCloud keys usually start with gsk_.
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile

# Supabase backend, database, and authentication.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

